# Public site URL (no trailing slash) — used for sitemap, canonical links, and Open Graph
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Copy to .env.local (Next.js + npm run ingest both load this file)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: value only (not `NYT-S=...`) from browser cookies for logged-in nytimes.com — enables Mini Crossword fetch
NYT_S=
